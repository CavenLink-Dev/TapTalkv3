{
  "expo": {
    "name": "TapTalk",
    "slug": "taptalk",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "taptalk",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.taptalk.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
