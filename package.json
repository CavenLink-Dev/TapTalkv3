{
  "name": "taptalk",
  "private": true,
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "import:mulberry": "tsx scripts/importMulberry.ts",
    "normalise:mulberry": "tsx scripts/normaliseMulberrySvg.ts",
    "build:exemplars": "tsx scripts/buildCategoryExemplars.ts",
    "audit:coverage": "tsx scripts/auditSymbolCoverage.ts",
    "audit:uniformity": "tsx scripts/auditSymbolUniformity.ts",
    "build:symbols": "npm run import:mulberry && npm run normalise:mulberry && npm run build:exemplars",
    "build:symbol-db": "tsx scripts/buildSymbolBrainDb.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.12",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-crypto": "~15.0.0",
    "expo-haptics": "~15.0.7",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.12",
    "expo-router": "~6.0.0",
    "expo-speech": "~14.0.7",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.8",
    "fuse.js": "^7.4.2",
    "papaparse": "^5.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "4.1.7",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.3"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "better-sqlite3": "^12.11.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "^19.1.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo"
  }
}
